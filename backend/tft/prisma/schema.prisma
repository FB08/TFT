generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "mysql"
}

model curriculum {
  id                String              @id @default(uuid())
  userId            String
  title             String
  description       String?
  course            String?
  book              String?
  difficulty        String?
  memo              String?
  createdAt         DateTime            @default(now())
  user              user                @relation(fields: [userId], references: [id], map: "Curriculum_userId_fkey")
  curriculumlessons curriculumlessons[]

  @@index([userId], map: "Curriculum_userId_fkey")
}

model curriculumlessons {
  id           String     @id @default(uuid())
  curriculumId String
  description  String?
  progress     String?
  homework     String?
  order        Int
  createdAt    DateTime   @default(now())
  curriculum   curriculum @relation(fields: [curriculumId], references: [id], map: "CurriculumLessons_curriculumId_fkey")

  @@index([curriculumId], map: "CurriculumLessons_curriculumId_fkey")
}

model homework {
  id             String          @id @default(uuid())
  lessonId       String
  content        String
  status         homework_status @default(ASSIGNED)
  assignedAt     DateTime        @default(now())
  carriedFromId  String?
  createdAt      DateTime        @default(now())
  homework       homework?       @relation("homeworkTohomework", fields: [carriedFromId], references: [id], map: "Homework_carriedFromId_fkey")
  other_homework homework[]      @relation("homeworkTohomework")
  lessonrecord   lessonrecord    @relation(fields: [lessonId], references: [id], map: "Homework_lessonId_fkey")

  @@index([carriedFromId], map: "Homework_carriedFromId_fkey")
  @@index([lessonId], map: "Homework_lessonId_fkey")
}

model lessonexception {
  id              String        @id @default(uuid())
  patternId       String
  originalStartAt DateTime
  isCanceled      Boolean       @default(false)
  newStartAt      DateTime
  newEndAt        DateTime?
  createdAt       DateTime      @default(now())
  lessonpattern   lessonpattern @relation(fields: [patternId], references: [id], map: "LessonException_patternId_fkey")

  @@index([patternId], map: "LessonException_patternId_fkey")
}

model lessonpattern {
  id              String            @id @default(uuid())
  studentId       String
  startTime       String
  endTime         String
  startDate       DateTime
  endDate         DateTime?
  rrule           String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  lessonexception lessonexception[]
  student         student           @relation(fields: [studentId], references: [id], map: "LessonPattern_studentId_fkey")

  @@index([studentId], map: "LessonPattern_studentId_fkey")
}

model lessonrecord {
  id            String     @id @default(uuid())
  studentId     String
  lessonStartAt DateTime
  progress      String?
  feedback      String?
  createdAt     DateTime   @default(now())
  homework      homework[]
  student       student    @relation(fields: [studentId], references: [id], map: "LessonRecord_studentId_fkey")
  todo          todo[]

  @@index([studentId], map: "LessonRecord_studentId_fkey")
}

model singlelesson {
  id        String   @id @default(uuid())
  studentId String
  startAt   DateTime
  endAt     DateTime
  createdAt DateTime @default(now())
  student   student  @relation(fields: [studentId], references: [id], map: "SingleLesson_studentId_fkey")

  @@index([studentId], map: "SingleLesson_studentId_fkey")
}

model student {
  id            String          @id @default(uuid())
  userId        String
  name          String?
  age           Int?
  sex           student_sex?
  address       String?
  phone         String?
  parentPhone   String?
  book          String?
  memo          String?
  payRate       Int?
  startedAt     DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lessonpattern lessonpattern[]
  lessonrecord  lessonrecord[]
  singlelesson  singlelesson[]
  user          user            @relation(fields: [userId], references: [id], map: "Student_userId_fkey")

  @@index([userId], map: "Student_userId_fkey")
}

model todo {
  id           String        @id @default(uuid())
  userId       String
  lessonId     String?
  content      String
  until        DateTime?
  createdAt    DateTime      @default(now())
  lessonrecord lessonrecord? @relation(fields: [lessonId], references: [id], map: "Todo_lessonId_fkey")
  user         user          @relation(fields: [userId], references: [id], map: "Todo_userId_fkey")

  @@index([lessonId], map: "Todo_lessonId_fkey")
  @@index([userId], map: "Todo_userId_fkey")
}

model user {
  id               String       @id @default(uuid())
  userId           String       @unique(map: "User_userId_key")
  passwordHash     String
  deletedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  refreshTokenHash String       @db.VarChar(255)
  name             String       @db.VarChar(20)
  curriculum       curriculum[]
  student          student[]
  todo             todo[]
}

enum homework_status {
  ASSIGNED
  COMPLETE
  CARRIED_OVER
  CANCELED
}

enum student_sex {
  Male
  Female
}
